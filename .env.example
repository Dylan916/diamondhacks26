# -----------------------------------------------------------------------------
# Course2Calendar Environment Variables
# -----------------------------------------------------------------------------

# Gemini 3.1 Flash API Key — Get one for free at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_key_here

# Browser Use Cloud API Key — Get one at https://cloud.browser-use.com
BROWSER_USE_API_KEY=your_browser_use_cloud_key_here

# Browser Use Profile ID (Optional) — Pre-saved browser profile for faster syncs
BROWSER_USE_PROFILE_ID=your_optional_profile_id_here

# Syllabus URLs are entered directly into the dashboard UI.
