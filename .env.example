# Gemini API Key — free at https://aistudio.google.com (no credit card)
GEMINI_API_KEY=your_gemini_api_key_here

# Notion Integration Token — create at https://www.notion.so/my-integrations
NOTION_TOKEN=your_notion_integration_token_here

# Notion Database ID — the ID from your database page URL
# e.g. https://notion.so/MyDatabase?v=...&p=<DATABASE_ID>
NOTION_DATABASE_ID=your_notion_database_id_here

# NOTE: Canvas credentials are entered by the student in the UI each session.
# They are never stored here or anywhere in the backend.
